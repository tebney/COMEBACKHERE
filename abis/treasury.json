    "4": "AlreadyExecuted",
    "5": "ThresholdNotMet",
    "6": "ThresholdNotConfigured",
    "7": "InvalidAmount",
    "8": "ContractPaused",
    "9": "Unauthorized",
    "10": "UnauthorizedSigner",
